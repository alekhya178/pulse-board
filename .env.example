# Redis Configuration
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Application
PORT=3000
NODE_ENV=development

# Session
SESSION_TTL_SECONDS=86400

# Rate Limiting
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW_SECONDS=60

# Distributed Lock
LOCK_TTL_SECONDS=30

# Activity Feed
FEED_MAX_LENGTH=100

# Job Queue
JOB_QUEUE_KEY=queue:jobs

# Redis Streams
EVENT_STREAM_KEY=stream:events
STREAM_CONSUMER_GROUP=workers
STREAM_CONSUMER_NAME=worker-1
